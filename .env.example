# Credentials for the gated /admin/* area (HTTP Basic Auth via proxy.ts).
# Copy this file to .env.local and set real values. .env.local is gitignored.
# If either is unset, /admin/* returns 503 (locked) rather than being public.
ADMIN_USER=professor
ADMIN_PASS=change-me

# Supabase — meetings backend (see supabase.md). Uses Supabase's current key
# system: the PUBLISHABLE key (sb_publishable_…) is RLS-bound and safe to expose
# (hence NEXT_PUBLIC_); it powers public reads. The SECRET key (sb_secret_…)
# bypasses RLS and is used only by the gated /admin/schedule write actions — keep
# it server-side, never NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
